# MCP Gateway - Environment Variables
# Copy to .env and customize for your deployment.

# Gateway settings
MCP_GATEWAY_PORT=8080
MCP_GATEWAY_LOG_LEVEL=info

# API key (uncomment to require auth for all requests)
# MCP_GATEWAY_API_KEY=your-secret-key-here

# Backend server URLs (used in config.yaml via ${VAR_NAME})
# FLEET_SERVER_URL=http://host.docker.internal:3001/mcp
# MONITORING_SERVER_URL=http://host.docker.internal:3002/mcp
# CLOUD_SERVICES_URL=http://host.docker.internal:3003/mcp

# Backend auth tokens
# FLEET_TOKEN=your-fleet-api-token
# MONITORING_TOKEN=your-monitoring-api-token
